@page "/brownian-motion"
@using MudBlazor
@using MudBlazor.Charts
@using Pricer.Numerics

<MudPaper Class="pa-4">
    <MudText Typo="Typo.h5">Brownian Motion Simulator</MudText>

    <MudGrid Class="mt-4" GutterSize="3">
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                <MudNumericField T="double" @bind-Value="timeHorizon" Label="Time Horizon (years)" Immediate="true" Min="0.1" Max="50" />
                <MudNumericField T="double" @bind-Value="drift" Label="Drift (μ)" Immediate="true" Class="mt-3" />
                <MudNumericField T="double" @bind-Value="volatility" Label="Volatility (σ)" Immediate="true" Class="mt-3" Min="0.001" />
                <MudNumericField T="int" @bind-Value="numPaths" Label="Paths" Immediate="true" Class="mt-3" Min="1" Max="5" />
                <MudButton Class="mt-4" Variant="Variant.Filled" Color="Color.Primary" OnClick="Simulate" FullWidth="true">Simulate</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="8">
            <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                <MudText Typo="Typo.subtitle1" Class="mb-2">
                    Random Walk → Brownian Motion
                </MudText>
                <MudText Typo="Typo.body2" Class="mb-3">
                    @GetStepsDescription()
                </MudText>
                <MudSlider T="int" 
                           @bind-Value="steps" 
                           Min="10" 
                           Max="500" 
                           Step="10"
                           ValueLabel="true"
                           Color="Color.Primary"
                           Immediate="true"
                           ValueLabelFormat="@($"{steps} steps (Δt = {(timeHorizon/steps):F4})")"
                           Class="mt-2">
                    <MudText Typo="Typo.caption">Steps: @steps</MudText>
                </MudSlider>
                <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Coarse Random Walk</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Fine Brownian Motion</MudText>
                </MudStack>

                <MudDivider Class="my-4" />

                <MudText Typo="Typo.subtitle1" Class="mb-2">
                    Volatility Scaling: σ · (Δt)^α
                </MudText>
                <MudText Typo="Typo.body2" Class="mb-3">
                    @GetScalingDescription()
                </MudText>
                <MudSlider T="double" 
                           @bind-Value="scalingExponent" 
                           Min="0.2" 
                           Max="0.8" 
                           Step="0.05"
                           ValueLabel="true"
                           Color="Color.Primary"
                           Immediate="true"
                           ValueLabelFormat="@($"α = {scalingExponent:F2}")"
                           Class="mt-2">
                    <MudText Typo="Typo.caption">Exponent: @scalingExponent.ToString("F2")</MudText>
                </MudSlider>
                <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-2">
                    <MudText Typo="Typo.caption" Color="Color.Error">Freezing (α &lt; 0.5)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Success">Brownian (α = 0.5)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Warning">Explosion (α &gt; 0.5)</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Class="pa-2 mt-4">
    <MudChart T="double"
              ChartType="ChartType.Timeseries"
              ChartSeries="@series"
              ChartOptions="@options"
              Width="100%" 
              Height="500px"
              MatchBoundsToSize="true" />
</MudPaper>

<MudDivider Class="my-6" />

<MudPaper Class="pa-4">
    <MudText Typo="Typo.h5">Correlated Brownian Motions</MudText>

    <MudGrid Class="mt-4" GutterSize="3">
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                <MudNumericField T="double" @bind-Value="correlatedTimeHorizon" Label="Time Horizon (years)" Immediate="true" Min="0.1" Max="50" />
                <MudNumericField T="double" @bind-Value="correlatedDrift" Label="Drift (μ)" Immediate="true" Class="mt-3" />
                <MudNumericField T="double" @bind-Value="correlatedVolatility" Label="Volatility (σ)" Immediate="true" Class="mt-3" Min="0.001" />
                <MudNumericField T="int" @bind-Value="correlatedSteps" Label="Steps" Immediate="true" Class="mt-3" Min="10" Max="500" />
                <MudButton Class="mt-4" Variant="Variant.Filled" Color="Color.Primary" OnClick="SimulateCorrelated" FullWidth="true">Simulate</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="8">
            <MudPaper Class="pa-4" Elevation="2" Style="height: 100%;">
                <MudText Typo="Typo.subtitle1" Class="mb-2">
                    Correlation Coefficient
                </MudText>
                <MudText Typo="Typo.body2" Class="mb-3">
                    @GetCorrelationDescription()
                </MudText>
                <MudSlider T="double"
                           @bind-Value="correlationCoefficient"
                           Min="-1.0"
                           Max="1.0"
                           Step="0.05"
                           ValueLabel="true"
                           Color="Color.Primary"
                           Immediate="true"
                           ValueLabelFormat="@($"ρ = {correlationCoefficient:F2}")"
                           Class="mt-2">
                    <MudText Typo="Typo.caption">Correlation: @correlationCoefficient.ToString("F2")</MudText>
                </MudSlider>
                <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mt-2">
                    <MudText Typo="Typo.caption" Color="Color.Error">Perfect Negative (ρ = -1)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Info">Independent (ρ = 0)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Success">Perfect Positive (ρ = 1)</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Class="pa-2 mt-4">
    <MudChart T="double"
              ChartType="ChartType.Timeseries"
              ChartSeries="@correlatedSeries"
              ChartOptions="@correlatedOptions"
              Width="100%" 
              Height="500px"
              MatchBoundsToSize="true" />
</MudPaper>

@code {
    private double timeHorizon = 1.0;
    private int steps = 252;
    private double drift = 0.0;
    private double volatility = 1.0;
    private int numPaths = 1;
    private double scalingExponent = 0.5;

    private List<ChartSeries<double>> series = [];
    private TimeSeriesChartOptions options = new();

    // Correlated Brownian Motion properties
    private double correlatedTimeHorizon = 1.0;
    private int correlatedSteps = 252;
    private double correlatedDrift = 0.0;
    private double correlatedVolatility = 1.0;
    private double correlationCoefficient = 0.5;
    private List<ChartSeries<double>> correlatedSeries = [];
    private TimeSeriesChartOptions correlatedOptions = new();

    private BrownianMotionGenerator _brownianGenerator = new();

    protected override void OnInitialized() => Simulate();

    protected override void OnParametersSet()
    {
        Simulate();
    }

    private string GetStepsDescription()
    {
        double dt = timeHorizon / steps;
        if (steps < 50)
            return $"With {steps} steps, you see a coarse random walk with large jumps (Δt = {dt:F4}). Each step is clearly visible.";
        else if (steps < 150)
            return $"With {steps} steps, the path is smoother. The discrete nature is still visible but less pronounced (Δt = {dt:F4}).";
        else
            return $"With {steps} steps, the path closely approximates continuous Brownian motion (Δt = {dt:F4}). The discrete jumps are barely visible.";
    }

    private string GetScalingDescription()
    {
        if (scalingExponent < 0.45)
            return $"With α = {scalingExponent:F2} < 0.5, the variance scales too slowly. As Δt → 0, the path 'freezes' and flattens. Not a proper limit.";
        else if (scalingExponent < 0.55)
            return $"With α = {scalingExponent:F2} ≈ 0.5, the variance scales correctly as √Δt. This gives proper Brownian motion in the limit.";
        else
            return $"With α = {scalingExponent:F2} > 0.5, the variance scales too fast. As Δt → 0, the path 'explodes' and becomes unbounded. Not a proper limit.";
    }

    private string GetCorrelationDescription()
    {
        if (correlationCoefficient < -0.8)
            return $"With ρ = {correlationCoefficient:F2}, the two motions move strongly in opposite directions. When one goes up, the other tends to go down.";
        else if (correlationCoefficient < -0.2)
            return $"With ρ = {correlationCoefficient:F2}, there's negative correlation. The motions tend to move in opposite directions, but not perfectly.";
        else if (correlationCoefficient < 0.2)
            return $"With ρ = {correlationCoefficient:F2}, the motions are nearly independent. Their movements are largely uncorrelated.";
        else if (correlationCoefficient < 0.8)
            return $"With ρ = {correlationCoefficient:F2}, there's positive correlation. The motions tend to move in the same direction, but not perfectly.";
        else
            return $"With ρ = {correlationCoefficient:F2}, the two motions move strongly together. When one goes up, the other tends to go up as well.";
    }

    private void Simulate()
    {
        var startDate = new DateTime(DateTime.Now.Year, 1, 1);
        var paths = _brownianGenerator.GeneratePaths(timeHorizon, steps, drift, volatility, scalingExponent, numPaths, startDate);

        options = new TimeSeriesChartOptions
        {
            InterpolationOption = InterpolationOption.Straight,
            LineStrokeWidth = 2,
            TimeLabelFormat = "MM/yyyy",
            TimeLabelSpacing = TimeSpan.FromDays(90),
            TimeLabelSpacingRounding = true
        };

        series = [];
        for (int p = 0; p < paths.Count; p++)
        {
            var data = new List<TimeValue<double>>();
            foreach (var point in paths[p])
            {
                data.Add(new TimeValue<double>(point.Time, point.Value));
            }

            series.Add(new ChartSeries<double>
            {
                Name = numPaths > 1 ? $"Path {p + 1}" : "W(t)",
                Data = data
            });
        }
    }

    private void SimulateCorrelated()
    {
        var startDate = new DateTime(DateTime.Now.Year, 1, 1);
        var (path1, path2) = _brownianGenerator.GenerateCorrelatedPaths(
            correlatedTimeHorizon, correlatedSteps, correlatedDrift, correlatedVolatility, correlationCoefficient, startDate);

        correlatedOptions = new TimeSeriesChartOptions
        {
            InterpolationOption = InterpolationOption.Straight,
            LineStrokeWidth = 2,
            TimeLabelFormat = "MM/yyyy",
            TimeLabelSpacing = TimeSpan.FromDays(90),
            TimeLabelSpacingRounding = true
        };

        var data1 = new List<TimeValue<double>>();
        var data2 = new List<TimeValue<double>>();

        foreach (var point in path1)
        {
            data1.Add(new TimeValue<double>(point.Time, point.Value));
        }

        foreach (var point in path2)
        {
            data2.Add(new TimeValue<double>(point.Time, point.Value));
        }

        correlatedSeries = new List<ChartSeries<double>>
        {
            new ChartSeries<double>
            {
                Name = "W₁(t)",
                Data = data1
            },
            new ChartSeries<double>
            {
                Name = "W₂(t)",
                Data = data2
            }
        };
    }
}
